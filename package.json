{
  "name": "multipitch",
  "version": "0.1.0",
  "description": "Browser-first multi-pitch detection using a Klapuri-style harmonic summation approach",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/copy-worklet.mjs",
    "demo": "npm run build && node demo/server.mjs",
    "demo:serve": "node demo/server.mjs",
    "evaluate:wav": "npm run build && node scripts/evaluate-wav.mjs",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "pitch",
    "detection",
    "music",
    "audio",
    "dsp",
    "web-audio",
    "polyphonic",
    "klapuri"
  ],
  "author": "Luke Nila",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "fft.js": "^4.0.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
